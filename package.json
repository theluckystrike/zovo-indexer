{
  "name": "zovo-indexer",
  "version": "1.0.0",
  "description": "Safe, free indexing tool for Extension Insiders using official APIs - Index your Chrome extensions to Google Search Console using official indexing APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./google-indexer": {
      "import": "./dist/google-indexer.js",
      "types": "./dist/google-indexer.d.ts"
    },
    "./indexnow": {
      "import": "./dist/indexnow.js",
      "types": "./dist/indexnow.d.ts"
    },
    "./sitemap-parser": {
      "import": "./dist/sitemap-parser.js",
      "types": "./dist/sitemap-parser.d.ts"
    }
  },
  "bin": {
    "zovo-indexer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "commander": "^11.0.0",
    "dotenv": "^16.0.0",
    "fast-xml-parser": "^5.3.4",
    "googleapis": "^126.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "keywords": [
    "seo",
    "indexing",
    "google",
    "indexnow",
    "sitemap",
    "chrome-extension"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/zovo-indexer.git"
  },
  "license": "MIT"
}
